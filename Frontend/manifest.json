{
  "manifest_version": 3,
  "name": "Smart Tab Manager",
  "version": "1.0.0",
  "description": "Manage your tabs with auto-grouping and session saving",
  "permissions": ["tabs", "tabGroups", "storage", "sessions", "alarms", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "index.html"
  },
  "options_page": "options.html"
}